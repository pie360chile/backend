# Ejemplo — copiar a .env (no commitear secretos reales)
DATABASE_URL=mysql+pymysql://user:pass@host:3306/pie360
SECRET_KEY=change-me
ALGORITHM=HS256
# Carpeta raíz de archivos del backend (documentos, estudiantes, etc.).
# NO incluyas agents/ ni el id del agente: el backend crea solo
#   {FILES_DIR}/agents/{WORKSPACE_AGENT_ID}/
# Local (Windows): C:/Users/jesus/Desktop/proyecto_pie360/backend/files
# Producción: ruta donde ya guarda archivos el ERP
FILES_DIR=/var/www/pie360backend.cl/public_html/files
CORS_ORIGINS=http://localhost:3002,http://127.0.0.1:3002,http://localhost:3001,http://127.0.0.1:3001,http://localhost:3000,http://127.0.0.1:3000,https://newerp-ghdegyc9cpcpc6gq.eastus-01.azurewebsites.net
INSPECTION_API_BASE_URL=
INSPECTION_API_USERNAME=
INSPECTION_API_PASSWORD=
# Token para ChatGPT MCP (Authentication → Access token / API key)
# URL en ChatGPT: https://pie360backend.cl/api/mcp
MCP_SECRET=
API_PUBLIC_BASE=https://pie360backend.cl/api
WORKSPACE_AGENT_ID=agtch_6a35d3014cbc8191911eed3847b3e8fe
WORKSPACE_AGENT_NAME=Redactor de Informes PIE
WORKSPACE_AGENT_API_BASE=https://api.chatgpt.com/v1/workspace_agents
AGENT_ACCESS_TOKEN=
# Google Drive — fallback dev si no hay fila en schools_settings (por school_id).
# Producción: guardar google_drive_root_folder_id + google_service_account_json en BD.
GOOGLE_DRIVE_CREDENTIALS_PATH=/ruta/a/service-account.json
GOOGLE_DRIVE_ROOT_FOLDER_ID=
